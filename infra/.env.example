# infra/.env.example
# Copy to .env and fill in all values marked REQUIRED.
# .env is gitignored — never commit it.
#
# Generation helpers:
#   Strong password (hex, URL-safe): openssl rand -hex 32
#   64-char hex key:                 openssl rand -hex 32
#   LiteLLM master key:              echo "sk-$(openssl rand -hex 24)"
#
# IMPORTANT: Use hex (not base64) for all passwords — base64 output contains
# '/', '@', '=' which break URL-formatted connection strings (Prisma, Redis).

# ── Network / Homelab ──────────────────────────────────────────
# Tailscale IP of this host (used for Temporal gRPC port binding in homelab mode).
# Find with: docker exec tailscale tailscale ip -4
TAILSCALE_IP=100.64.0.1

# Base domain and internal subdomain — must match your homelab Traefik config.
# Services will be exposed at {service}.{INTERNAL_SUBDOMAIN}.{DOMAIN}
# e.g. langfuse.mw.bluewonder.org
DOMAIN=your-domain.com
INTERNAL_SUBDOMAIN=home

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                          # REQUIRED — openssl rand -hex 32
POSTGRES_PORT=5433                          # 5433 avoids collision with homelab postgres on 5432

# ── Temporal ───────────────────────────────────────────────────
# TEMPORAL_CORS_ORIGINS: add your dashboard URL if accessing Temporal UI via Traefik
TEMPORAL_CORS_ORIGINS=http://localhost:8080

# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                          # REQUIRED — sk-ant-...

# ── LiteLLM ────────────────────────────────────────────────────
# Master key: used by workers to authenticate against LiteLLM proxy.
# Convention: prefix with sk- so it looks like an API key.
LITELLM_MASTER_KEY=                         # REQUIRED — sk-<openssl rand -hex 32>

# Langfuse keys for LiteLLM → Langfuse callback.
# Obtain AFTER first Langfuse login: Settings → Projects → API Keys → Create.
# Leave blank until Langfuse is running; LiteLLM will operate without tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── ClickHouse ─────────────────────────────────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=                        # REQUIRED — openssl rand -hex 32

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=                             # REQUIRED — openssl rand -hex 32

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=                        # REQUIRED — min 8 chars, openssl rand -hex 16

# ── Langfuse ───────────────────────────────────────────────────
# NEXTAUTH_URL: full URL where Langfuse web is reachable (used for OAuth redirects).
# Update to your Traefik hostname once it's routed.
LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# NEXTAUTH_SECRET: any random string, used to sign session tokens.
LANGFUSE_NEXTAUTH_SECRET=                   # REQUIRED — openssl rand -hex 32

# SALT: used for hashing API keys before storage.
LANGFUSE_SALT=                              # REQUIRED — openssl rand -hex 32

# ENCRYPTION_KEY: encrypts stored API keys at rest. MUST be 64 hex chars (32 bytes).
# Loss of this key = loss of all stored API key values. Back it up.
LANGFUSE_ENCRYPTION_KEY=                    # REQUIRED — openssl rand -hex 32

# ── Langfuse seed (first run only, idempotent) ─────────────────
# Creates initial org/project/user on first startup.
# After setup, API keys are managed in the UI — these vars have no effect on re-runs.
LANGFUSE_INIT_ORG_ID=factory-org
LANGFUSE_INIT_ORG_NAME=Factory
LANGFUSE_INIT_PROJECT_ID=project-engine
LANGFUSE_INIT_PROJECT_NAME=project-engine
LANGFUSE_INIT_USER_EMAIL=                   # REQUIRED for seed — your email
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=               # REQUIRED for seed — strong password
